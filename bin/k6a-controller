#!/system/bin/sh
# ═══════════════════════════════════════════════════════════════════════════════
# k6a-controller  v7.28
# SM7150 (Snapdragon 730G) / sweet_k6a — Lunaris 3.8 AOSP / Openela 4.14.356
#
# ALLE sysfs-Nodes in dieser Version gegen echtes Gerät via Termux verifiziert.
# Keine toten Writes mehr. Jede Zeile hat einen echten Node dahinter.
#
# VERIFIED HARDWARE MAP (Termux, 2025):
# ──────────────────────────────────────
#  CPU Silver  cpu0-5  policy0  OPPs: 576 768 1017 1248 1324 1497 1612 1708 1804 MHz
#  CPU Gold    cpu6-7  policy6  OPPs: 652 806 979 1094 1209 1324 1555 1708 1843 1939 2169 2208 2304 MHz
#  GPU Adreno 618  /sys/class/kgsl/kgsl-3d0
#       pwrlevels (num=8): 0=800 1=650 2=565 3=430 4=355 5=267 6=180 7=140 MHz
#       governor: msm-adreno-tz
#       devfreq nodes: min_freq max_freq cur_freq governor polling_interval
#       NO min_freq_bus (existiert NICHT auf diesem Kernel!)
#  Kernel  CONFIG_HZ=100 | CONFIG_SCHED_WALT=y | CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
#          CONFIG_CPU_BOOST=n | CONFIG_MSM_PERFORMANCE=n
#          NO /policy0/schedutil/ subdir (existiert nicht!)
#          NO core_ctl (/cpu0/core_ctl/ existiert nicht!)
#  Scheduler  VORHANDEN: sched_upmigrate sched_downmigrate sched_child_runs_first
#             sched_energy_aware sched_util_clamp_min/max
#             NICHT VORHANDEN: sched_boost, sched_window_stats_policy,
#             sched_ravg_hist_size, sched_init_task_load_pct,
#             sched_freq_aggr_threshold_pct, sched_migration_cost_ns
#  schedtune  IN /dev/cpuset/*/schedtune.boost + schedtune.prefer_idle ✅
#             uclamp.min uclamp.max uclamp.boosted uclamp.latency_sensitive ✅
#             /dev/stune/ dirs sind LEER — schedtune dort nicht nutzbar!
#  Thermal    zone24 = cpuss-0-usr (Silver Cluster) ← primärer Silver-Temp
#             zone25 = cpuss-1-usr (Gold Cluster)   ← primärer Gold-Temp
#             zone30 = gpuss-0-usr (GPU)
#             zone7/8 = pm6150-bcl-lvl1/2 = BCL — KEIN CPU-Temp! (v7.23 falsch)
#  LMK        /sys/module/lowmemorykiller/parameters/minfree ✅ (nur minfree!)
#
# v7.24 Changes vs v7.23:
#   - GPU pwrlevels komplett neu (verifiziert): 0=800 1=650 2=565 3=430 4=355 5=267 6=180 7=140
#   - GPU devfreq/min_freq_bus ENTFERNT (Node existiert nicht)
#   - Thermal zones korrigiert: zone24=Silver zone25=Gold (war zone7/8=BCL!)
#   - schedutil subdir ENTFERNT (/policy0/schedutil/ existiert nicht)
#   - schedtune Pfad: /dev/cpuset/* statt /dev/stune/* (verifiziert)
#   - uclamp via /dev/cpuset/*/uclamp.* (als String "0.00"-"100.00")
#   - cpu_boost, msm_performance, core_ctl ENTFERNT (nicht vorhanden)
#   - 9 tote WALT sched_* Nodes entfernt
#   - LMK: nur minfree (kein adj Node)
#   - CPU min Silver: 300000→576000 (niedrigstes echtes OPP)
#   - CPU min Gold gaming: 1785600→1843200 (nächstes echtes OPP)
#   - scaling_boost_frequencies genutzt (verifiziert vorhanden)
#   - _COLOCATE_SET Flag entfernt (schedtune.colocate nicht vorhanden)
#
# v7.25 Changes vs v7.24:
#   - cpu_set_boost() + alle Aufrufe ENTFERNT
#     scaling_boost_frequencies Node existiert zwar aber ist leer/nicht nutzbar
#     (verifiziert: cat policy0/scaling_boost_frequencies → leer)
#     Boost läuft jetzt ausschließlich über schedtune.boost + uclamp.min
#
# v7.26 Changes vs v7.25:
#   1. gpu_balanced: thermal_pwrlevel=1→0 — Governor komplett frei, kein künstlicher Cap
#   2. thermal_cpu_temp: pm6150-tz Fallback-Zone beim Start einmalig cachen (TZ_FALLBACK)
#      statt jeden Aufruf alle Zones zu loopen
#   3. ping_stale=1 in data.txt wenn STATE=GAMING/COMPETITIVE — WebUI kann veralteten
#      Ping-Wert visuell kennzeichnen
#   4. clean_cache: vollständig async (Background-Subshell) — blockiert 3s-Loop nicht mehr
#      CACHE_LAST wird nach Abschluss vom Background-Job geschrieben
#
# v7.27 Changes vs v7.26:
#   1. thermal_cpu_temp(): -274°C (disabled zone) wird ignoriert → zone0 Fallback
#      zone0=pm6150-tz überlebt thermal_disable=1, liefert echte Temp (verifiziert)
#   2. _cache_fallback_zone(): zone0 direkt prüfen statt Loop — sofort gecacht
#   3. restore_battery_spoof(): schreibt echten BMS-Wert zurück in battery/temp
#      verhindert dauerhaft gespoofte Temperatur nach Toggle-OFF
#   4. net_gaming(): UDP-Optimierungen für CoD Mobile (DTLS primär UDP):
#      udp_rmem/wmem_min=32KB, tcp_low_latency=1, ARP-Cache, nf_conntrack UDP=30s
#
# v7.28 Changes vs v7.27 — Mobiles Netz Optimierung:
#   1. apply_irq_affinity(): IPA IRQ (verifiziert IRQ 73) → cpu2 (Silver)
#      RIL-Prozesse ipacm/netmgrd/qcrild → Silver (0x3f) gepinnt
#      Gold bleibt frei für RenderThread
#   2. net_gaming(): rmnet qdisc htb→pfifo_fast (weniger Shaping-Overhead)
#      Aktives Interface rmnet_data3 (verifiziert) + alle aktiven rmnet_*
#   3. net_gaming(): DNS 1.1.1.1/8.8.8.8 via ndc+setprop
#      net.dns1/2 war leer (verifiziert), netId=102 für rmnet_data3
#   4. net_restore(): qdisc + DNS zurücksetzen
# ═══════════════════════════════════════════════════════════════════════════════

MODDIR="${1:-/data/adb/modules/Bad4zz89_k6a_tweaks}"
CONFIG="$MODDIR/config/settings.conf"
FREEZE="$MODDIR/config/freeze.conf"
LOG="$MODDIR/config/service.log"
PROFILE="$MODDIR/config/active_profile"
DATA="$MODDIR/webroot/data.txt"
FREEZE_DUMP="$MODDIR/webroot/freeze_dump.txt"
CACHE_TRIGGER="$MODDIR/config/clean_cache_now"
CACHE_LAST="$MODDIR/config/cache_last_cleaned"
RAM_TRIGGER="$MODDIR/config/clean_ram_now"
MANUAL_P="$MODDIR/config/manual_profile"
LOCK="$MODDIR/run/controller.pid"

# ── Verified sysfs paths ──────────────────────────────────────────────────────
GPU=/sys/class/kgsl/kgsl-3d0
P0=/sys/devices/system/cpu/cpufreq/policy0   # Silver cpu0-5
P6=/sys/devices/system/cpu/cpufreq/policy6   # Gold   cpu6-7

# ── GPU pwrlevels — verifiziert: cat /sys/class/kgsl/kgsl-3d0/freq_table_mhz
# Output: 800 650 565 430 355 267 180 140  (8 levels, index 0=höchste Freq)
GPU_LVL_800=0    # TURBO — Gaming/Competitive max
GPU_LVL_650=1    # NOM   — Gaming floor (CoD braucht keine 800 konstant)
GPU_LVL_565=2    # SVS_L1
GPU_LVL_430=3    # SVS
GPU_LVL_355=4    # LOW_SVS — Battery ceiling
GPU_LVL_267=5    # MIN     — Stock default / Battery floor
GPU_LVL_180=6
GPU_LVL_140=7

# ── Thermal zones — verifiziert via Termux grep cpuss/gpuss ──────────────────
# zone24 = cpuss-0-usr (Silver Cluster) — primärer Silver-Temp
# zone25 = cpuss-1-usr (Gold Cluster)   — primärer Gold-Temp
# zone30 = gpuss-0-usr
# ACHTUNG: zone7/8 = pm6150-bcl-lvl1/2 (BCL!) — war falsch in v7.23!
TZ_GOLD="/sys/devices/virtual/thermal/thermal_zone25/temp"
TZ_SILVER="/sys/devices/virtual/thermal/thermal_zone24/temp"
TZ_GPU="/sys/devices/virtual/thermal/thermal_zone30/temp"

# ── cpuset — schedtune ist hier, NICHT in /dev/stune/ (stune ist leer!) ──────
CS_TOP="/dev/cpuset/top-app"
CS_FG="/dev/cpuset/foreground"
CS_BG="/dev/cpuset/background"
CS_SYS="/dev/cpuset/system-background"
CS_RESTRICT="/dev/cpuset/restricted"

# ── Runtime ───────────────────────────────────────────────────────────────────
STATE="IDLE"
PRE_THERMAL_STATE="BALANCED"
LAST_APP=""
LAST_CFG_MTIME=0
LAST_FREEZE_TRIGGER=""
TICK=0
_CODM_PID_CACHE=""
THERMAL_CAPPED=0
PREV_TEMP=-1
TZ_FALLBACK=""   # pm6150-tz Zone-Pfad — wird beim Start einmalig gecacht

# ═══════════════════════════════════════════════════════════════════════════════
# PRIMITIVES
# ═══════════════════════════════════════════════════════════════════════════════
log() { printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$1" >> "$LOG"; }
dbg() { [ "$DEBUG" = "1" ] && printf '[%s][DBG] %s\n' "$(date '+%H:%M:%S')" "$1" >> "$LOG"; }
cfg() { grep "^${1}=" "$CONFIG" 2>/dev/null | cut -d= -f2; }

_cfg_load_cache() {
    CFG_THERMAL=$(cfg thermal_disable);              CFG_THERMAL=${CFG_THERMAL:-0}
    CFG_AUTO=$(cfg auto_detection);                  CFG_AUTO=${CFG_AUTO:-0}
    CFG_SPOOF_EN=$(cfg battery_spoof_enable);        CFG_SPOOF_EN=${CFG_SPOOF_EN:-0}
    CFG_SPOOF_T=$(cfg battery_spoof_temp);           CFG_SPOOF_T=${CFG_SPOOF_T:-15}
    CFG_THERM_PRED=$(cfg thermal_prediction_enable); CFG_THERM_PRED=${CFG_THERM_PRED:-1}
    CFG_THREAD_PIN=$(cfg thread_pin_enable);         CFG_THREAD_PIN=${CFG_THREAD_PIN:-1}
    CFG_BOOT_DELAY=$(cfg boot_delay);                CFG_BOOT_DELAY=${CFG_BOOT_DELAY:-8}
    DEBUG=$(cfg debug); [ "$DEBUG" != "1" ] && DEBUG=0
}

# Atomic sysfs write
w() {
    local node="$1" val="$2"
    { [ -f "$node" ] || [ -e "$node" ]; } && echo "$val" > "$node" 2>/dev/null || true
}

trim_log() {
    [ -f "$LOG" ] || return
    local size
    size=$(wc -c < "$LOG" 2>/dev/null) || return
    if [ "$size" -gt 102400 ]; then
        local tmp="${LOG}.tmp"
        tail -c 51200 "$LOG" > "$tmp" && mv "$tmp" "$LOG"
        log "Log rotiert (war ${size} Bytes)"
    fi
}

RELOAD_FLAG=0
trap 'RELOAD_FLAG=1' HUP
DEBUG=$(cfg debug); [ "$DEBUG" != "1" ] && DEBUG=0

# ═══════════════════════════════════════════════════════════════════════════════
# THERMAL MANAGER — LickT approach
# ═══════════════════════════════════════════════════════════════════════════════
THERMAL_SAFE_PATTERN="touch|tsp|ts[0-9]|conn_therm|charger_therm|battery|bms|qcom-bms|quiet_therm|xo_therm|pa_therm|pm6150|pm6150l"

thermal_stop_daemons() {
    local pid svc
    for svc in vendor.thermal-engine mi_thermald thermal-engine thermald \
               android.hardware.thermal-service.qti vendor.thermal; do
        stop "$svc" 2>/dev/null || true
        setprop ctl.stop "$svc" 2>/dev/null || true
    done
    sleep 0.2
    for pid in $(pgrep -f "thermal" 2>/dev/null); do kill -9 "$pid" 2>/dev/null || true; done
    for pid in $(pgrep -x "mi_thermald" 2>/dev/null); do kill -9 "$pid" 2>/dev/null || true; done
    sleep 0.4
    local te_bin
    for te_bin in /vendor/bin/thermal-engine /system/bin/thermal-engine \
                  /vendor/bin/mi_thermald /system/bin/mi_thermald; do
        [ -f "$te_bin" ] || continue
        mount --bind /bin/true "$te_bin" 2>/dev/null && \
            log "Bind-mount: $te_bin → /bin/true" || true
    done
    for pid in $(pgrep -x "msm_irqbalance" 2>/dev/null); do kill -9 "$pid" 2>/dev/null || true; done
    if [ -f "/vendor/bin/msm_irqbalance" ]; then
        mount | grep -q "msm_irqbalance" || \
            mount --bind /bin/true /vendor/bin/msm_irqbalance 2>/dev/null || true
    fi
    for svc in irqbalance vendor.irqbalance msm_irqbalance; do
        stop "$svc" 2>/dev/null || true; setprop ctl.stop "$svc" 2>/dev/null || true
    done
    cmd thermalservice override-status 0 2>/dev/null || true
    setprop vendor.thermal.config "thermal-engine-off.conf" 2>/dev/null || true
    log "Thermal daemons: killed + bind-mount"
}

thermal_restore_daemons() {
    local te_bin svc
    for te_bin in /vendor/bin/thermal-engine /system/bin/thermal-engine \
                  /vendor/bin/mi_thermald /system/bin/mi_thermald \
                  /vendor/bin/msm_irqbalance; do
        umount "$te_bin" 2>/dev/null || true
        umount "$te_bin" 2>/dev/null || true
    done
    setprop vendor.thermal.config "" 2>/dev/null || true
    for svc in msm_irqbalance irqbalance vendor.irqbalance; do start "$svc" 2>/dev/null || true; done
    for svc in vendor.thermal-engine mi_thermald thermal-engine thermald \
               android.hardware.thermal-service.qti vendor.thermal; do
        start "$svc" 2>/dev/null || true
    done
    cmd thermalservice reset 2>/dev/null || true
    log "Thermal daemons: restored"
}

thermal_zones_disable() {
    local zone type
    for zone in /sys/devices/virtual/thermal/thermal_zone* \
                /sys/class/thermal/thermal_zone*; do
        [ -d "$zone" ] || continue
        type=$(cat "$zone/type" 2>/dev/null) || continue
        [ -z "$type" ] && continue
        echo "$type" | grep -qiE "$THERMAL_SAFE_PATTERN" && continue
        echo "$type" | grep -qiE "bcl|pm6150" && continue
        echo "$type" | grep -qiE "cpu|gpu|aoss|ddr|npu|video|cpuss|gpuss|lowf|step" || continue
        w "$zone/mode"       "disabled"
        w "$zone/thm_enable" "0"
    done
    log "Thermal zones: CPU/GPU/step/lowf disabled"
}

thermal_zones_restore() {
    local zone
    for zone in /sys/devices/virtual/thermal/thermal_zone* \
                /sys/class/thermal/thermal_zone*; do
        [ -d "$zone" ] || continue
        w "$zone/mode"       "enabled"
        w "$zone/thm_enable" "1"
    done
    log "Thermal zones: restored"
}

thermal_full_disable() { thermal_stop_daemons; thermal_zones_disable; }
thermal_full_restore()  { thermal_zones_restore; thermal_restore_daemons; }

# ── thermal_cpu_temp — verifizierte Zone-Indices ──────────────────────────────
# zone25 = cpuss-1-usr = Gold  (verifiziert) — aber disabled wenn thermal_disable=1!
# zone24 = cpuss-0-usr = Silver (verifiziert) — aber disabled wenn thermal_disable=1!
# zone0  = pm6150-tz ADC — überlebt thermal_zones_disable, mode=enabled IMMER
# Strategie: zone24/25 primär (genauer), zone0 als Fallback ODER wenn zones disabled
thermal_cpu_temp() {
    local best=0 t

    t=$(cat "$TZ_GOLD"   2>/dev/null || echo 0)
    # -274°C = zone disabled → ignorieren
    [ "${t:-0}" -gt 0 ] && best="$t"

    t=$(cat "$TZ_SILVER" 2>/dev/null || echo 0)
    [ "${t:-0}" -gt 0 ] && [ "${t:-0}" -gt "$best" ] && best="$t"

    # Fallback: zone0 (pm6150-tz) — überlebt thermal_disable, verifiziert zone0/temp=37000
    # Wird auch genutzt wenn best=0 (zones disabled durch thermal_disable=1)
    if [ "$best" -le 0 ] && [ -n "$TZ_FALLBACK" ]; then
        best=$(cat "$TZ_FALLBACK" 2>/dev/null || echo 0)
    fi

    printf '%d' $(( ${best:-0} / 1000 ))
}

# Einmalig beim Start — cached zone0 (pm6150-tz) Pfad
# Verifiziert: thermal_zone0/type=pm6150-tz, mode=enabled auch bei thermal_disable=1
_cache_fallback_zone() {
    # zone0 direkt prüfen (verifiziert via Termux)
    if [ "$(cat /sys/devices/virtual/thermal/thermal_zone0/type 2>/dev/null)" = "pm6150-tz" ]; then
        TZ_FALLBACK="/sys/devices/virtual/thermal/thermal_zone0/temp"
        log "TZ_FALLBACK: zone0 (pm6150-tz) gecacht — überlebt thermal_disable"
        return
    fi
    # Fallback-Loop falls zone0 nicht pm6150-tz ist
    local zone type
    for zone in /sys/devices/virtual/thermal/thermal_zone*; do
        [ -f "$zone/type" ] || continue
        type=$(cat "$zone/type" 2>/dev/null) || continue
        if echo "$type" | grep -qiE "^pm6150-tz$"; then
            TZ_FALLBACK="$zone/temp"
            log "TZ_FALLBACK: $zone gecacht"
            return
        fi
    done
    log "WARN: TZ_FALLBACK pm6150-tz nicht gefunden — thermal_predict deaktiviert"
}

# ═══════════════════════════════════════════════════════════════════════════════
# GPU — Adreno 618
# pwrlevels verifiziert: freq_table_mhz = 800 650 565 430 355 267 180 140
# devfreq hat KEIN min_freq_bus Node auf diesem Kernel!
# ═══════════════════════════════════════════════════════════════════════════════
gpu_gaming() {
    w $GPU/devfreq/governor        "msm-adreno-tz"
    w $GPU/force_clk_on            "1"
    w $GPU/force_bus_on            "1"
    w $GPU/bus_split               "0"
    w $GPU/max_pwrlevel            "$GPU_LVL_800"   # 800MHz ceiling
    w $GPU/min_pwrlevel            "$GPU_LVL_650"   # 650MHz floor
    w $GPU/devfreq/min_freq        "650000000"
    w $GPU/devfreq/max_freq        "800000000"
    w $GPU/devfreq/polling_interval "5"
    w $GPU/thermal_pwrlevel        "0"
    w $GPU/adreno_idler_active     "0"
    echo "0" > "$GPU/throttling"   2>/dev/null || true
    dbg "GPU gaming: 650-800MHz (pwrlevel 1→0)"
}

gpu_competitive() {
    w $GPU/devfreq/governor        "msm-adreno-tz"
    w $GPU/force_clk_on            "1"
    w $GPU/force_bus_on            "1"
    w $GPU/bus_split               "0"
    w $GPU/max_pwrlevel            "$GPU_LVL_800"
    w $GPU/min_pwrlevel            "$GPU_LVL_800"   # locked 800MHz
    w $GPU/devfreq/min_freq        "800000000"
    w $GPU/devfreq/max_freq        "800000000"
    w $GPU/devfreq/polling_interval "2"
    w $GPU/thermal_pwrlevel        "0"
    w $GPU/adreno_idler_active     "0"
    echo "0" > "$GPU/throttling"   2>/dev/null || true
    dbg "GPU competitive: locked 800MHz"
}

gpu_balanced() {
    w $GPU/devfreq/governor        "msm-adreno-tz"
    w $GPU/force_clk_on            "0"
    w $GPU/force_bus_on            "0"
    w $GPU/bus_split               "1"
    w $GPU/max_pwrlevel            "$GPU_LVL_800"
    w $GPU/min_pwrlevel            "$GPU_LVL_267"   # 267MHz stock floor
    w $GPU/devfreq/min_freq        "267000000"
    w $GPU/devfreq/max_freq        "800000000"
    w $GPU/thermal_pwrlevel        "0"              # Governor komplett frei (war 1=650MHz cap)
    w $GPU/adreno_idler_active     "1"
    echo "1" > "$GPU/throttling"   2>/dev/null || true
    dbg "GPU balanced: 267-800MHz, thermal_pwrlevel=0 (governor free), idler ON"
}

gpu_battery() {
    w $GPU/devfreq/governor        "powersave"
    w $GPU/force_clk_on            "0"
    w $GPU/force_bus_on            "0"
    w $GPU/bus_split               "1"
    w $GPU/max_pwrlevel            "$GPU_LVL_355"   # 355MHz ceiling
    w $GPU/min_pwrlevel            "$GPU_LVL_267"   # 267MHz floor
    w $GPU/devfreq/min_freq        "267000000"
    w $GPU/devfreq/max_freq        "355000000"
    w $GPU/thermal_pwrlevel        "2"
    w $GPU/adreno_idler_active     "1"
    dbg "GPU battery: powersave 267-355MHz"
}

# ═══════════════════════════════════════════════════════════════════════════════
# CPU FREQUENCY
# Silver OPPs: 576 768 1017 1248 1324 1497 1612 1708 1804 MHz
# Gold   OPPs: 652 806 979 1094 1209 1324 1555 1708 1843 1939 2169 2208 2304 MHz
# 300000/1785600 existieren NICHT — auf nächste echte OPPs korrigiert
# ═══════════════════════════════════════════════════════════════════════════════
cpu_set() {
    local gov="$1" smin="$2" smax="$3" gmin="$4" gmax="$5" c
    w "$P0/scaling_governor"  "$gov"
    w "$P0/scaling_min_freq"  "$smin"
    w "$P0/scaling_max_freq"  "$smax"
    w "$P6/scaling_governor"  "$gov"
    w "$P6/scaling_min_freq"  "$gmin"
    w "$P6/scaling_max_freq"  "$gmax"
    for c in 0 1 2 3 4 5; do
        w /sys/devices/system/cpu/cpu${c}/cpufreq/scaling_governor  "$gov"
        w /sys/devices/system/cpu/cpu${c}/cpufreq/scaling_min_freq  "$smin"
        w /sys/devices/system/cpu/cpu${c}/cpufreq/scaling_max_freq  "$smax"
    done
    for c in 6 7; do
        w /sys/devices/system/cpu/cpu${c}/cpufreq/scaling_governor  "$gov"
        w /sys/devices/system/cpu/cpu${c}/cpufreq/scaling_min_freq  "$gmin"
        w /sys/devices/system/cpu/cpu${c}/cpufreq/scaling_max_freq  "$gmax"
    done
}


# ═══════════════════════════════════════════════════════════════════════════════
# IRQ AFFINITY
# ═══════════════════════════════════════════════════════════════════════════════
apply_irq_affinity() {
    for pid in $(pgrep -x "msm_irqbalance" 2>/dev/null); do kill -9 "$pid" 2>/dev/null || true; done
    for pid in $(pidof irqbalance 2>/dev/null); do kill -9 "$pid" 2>/dev/null || true; done
    local irq_dir irq_name
    for irq_dir in /proc/irq/*/; do
        [ -f "${irq_dir}actions" ] || continue
        irq_name=$(cat "${irq_dir}actions" 2>/dev/null); [ -z "$irq_name" ] && continue
        if echo "$irq_name" | grep -qiE "goodix|synaptics|fts_touch|gt9|focal|touch_irq|touchscreen"; then
            printf '%s' "40" > "${irq_dir}smp_affinity" 2>/dev/null || true  # cpu6
        elif echo "$irq_name" | grep -qiE "kgsl|kgsl3d|adreno"; then
            printf '%s' "40" > "${irq_dir}smp_affinity" 2>/dev/null || true  # cpu6
        elif echo "$irq_name" | grep -qiE "ufshc|ufs|mmc|sdhci"; then
            printf '%s' "02" > "${irq_dir}smp_affinity" 2>/dev/null || true  # cpu1
        elif echo "$irq_name" | grep -qiE "wlan|rmnet|gsi|qcom-net"; then
            printf '%s' "04" > "${irq_dir}smp_affinity" 2>/dev/null || true  # cpu2
        elif echo "$irq_name" | grep -qiE "^ipa$|ipa_smp2p"; then
            # IPA (IP Accelerator) — verifiziert IRQ 73, aktiv bei rmnet_data3
            # cpu2 (0x04) = Silver → IPA-Interrupts blockieren Gold nicht
            printf '%s' "04" > "${irq_dir}smp_affinity" 2>/dev/null || true  # cpu2
            dbg "IPA IRQ ($irq_name) → cpu2 (0x04/Silver)"
        fi
    done

    # RIL/Modem Prozesse auf Silver pinnen — Gold bleibt frei für RenderThread
    local p
    for p in $(pidof ipacm   2>/dev/null); do taskset -p 0x3f "$p" >/dev/null 2>&1; done
    for p in $(pidof netmgrd 2>/dev/null); do taskset -p 0x3f "$p" >/dev/null 2>&1; done
    for p in $(pidof qcrild  2>/dev/null); do taskset -p 0x3f "$p" >/dev/null 2>&1; done
    dbg "IRQ: Touch/GPU→cpu6(40) UFS→cpu1(02) Net/IPA→cpu2(04) | RIL→Silver"
}

# ═══════════════════════════════════════════════════════════════════════════════
# SCHEDULER
# VERIFIZIERT VORHANDEN:
#   /proc/sys/kernel/sched_upmigrate            ✅
#   /proc/sys/kernel/sched_downmigrate          ✅
#   /proc/sys/kernel/sched_child_runs_first     ✅
#   /proc/sys/kernel/sched_util_clamp_min/max   ✅
#   /dev/cpuset/*/schedtune.boost               ✅
#   /dev/cpuset/*/schedtune.prefer_idle         ✅
#   /dev/cpuset/*/uclamp.min/max/boosted        ✅
#
# ENTFERNT (existieren nicht):
#   sched_boost, sched_window_stats_policy, sched_ravg_hist_size
#   sched_init_task_load_pct, sched_freq_aggr_threshold_pct
#   sched_migration_cost_ns, sched_freq_inc/dec_notify
#   /dev/stune/* (leer!), /policy0/schedutil/ (existiert nicht!)
#   cpu_boost, msm_performance, core_ctl
# ═══════════════════════════════════════════════════════════════════════════════
sched_gaming() {
    # cpuset
    echo "0-7" > "$CS_TOP/cpus"      2>/dev/null || true
    echo "0-7" > "$CS_FG/cpus"       2>/dev/null || true
    echo "0-5" > "$CS_SYS/cpus"      2>/dev/null || true
    echo "0-5" > "$CS_BG/cpus"       2>/dev/null || true
    echo "2-5" > "$CS_RESTRICT/cpus" 2>/dev/null || true

    # schedtune — IN /dev/cpuset/ (verifiziert, NICHT /dev/stune/)
    w "$CS_TOP/schedtune.boost"          "10"
    w "$CS_TOP/schedtune.prefer_idle"    "1"
    w "$CS_FG/schedtune.boost"           "5"
    w "$CS_FG/schedtune.prefer_idle"     "1"
    w "$CS_BG/schedtune.boost"           "0"
    w "$CS_BG/schedtune.prefer_idle"     "0"

    # uclamp — String-Format "0.00"-"100.00" (verifiziert als root les/schreibbar)
    w "$CS_TOP/uclamp.min"               "20.00"
    w "$CS_TOP/uclamp.max"               "100.00"
    w "$CS_TOP/uclamp.boosted"           "1"
    w "$CS_TOP/uclamp.latency_sensitive" "1"
    w "$CS_FG/uclamp.min"                "10.00"
    w "$CS_FG/uclamp.max"                "100.00"
    w "$CS_FG/uclamp.boosted"            "1"
    w "$CS_FG/uclamp.latency_sensitive"  "1"

    # sched — verifiziert vorhanden
    w /proc/sys/kernel/sched_upmigrate      "80"
    w /proc/sys/kernel/sched_downmigrate    "60"
    w /proc/sys/kernel/sched_child_runs_first "1"

    apply_irq_affinity
    w /sys/class/power_supply/battery/system_temp_level "0"
    dbg "Sched gaming: cpuset+schedtune+uclamp, upmigrate=80/60"
}

sched_balanced() {
    echo "0-7" > "$CS_TOP/cpus"      2>/dev/null || true
    echo "0-7" > "$CS_FG/cpus"       2>/dev/null || true
    w "$CS_TOP/schedtune.boost"          "0"
    w "$CS_TOP/schedtune.prefer_idle"    "0"
    w "$CS_FG/schedtune.boost"           "0"
    w "$CS_FG/schedtune.prefer_idle"     "0"
    w "$CS_TOP/uclamp.min"               "0.00"
    w "$CS_TOP/uclamp.max"               "100.00"
    w "$CS_TOP/uclamp.boosted"           "0"
    w "$CS_TOP/uclamp.latency_sensitive" "0"
    w "$CS_FG/uclamp.min"                "0.00"
    w "$CS_FG/uclamp.max"                "100.00"
    w "$CS_FG/uclamp.boosted"            "0"
    w "$CS_FG/uclamp.latency_sensitive"  "0"
    w /proc/sys/kernel/sched_upmigrate   "95"
    w /proc/sys/kernel/sched_downmigrate "85"
    w /proc/sys/kernel/sched_child_runs_first "0"
}

# ═══════════════════════════════════════════════════════════════════════════════
# VM / ZRAM
# ═══════════════════════════════════════════════════════════════════════════════
vm_gaming() {
    w /proc/sys/vm/swappiness               "10"
    w /proc/sys/vm/vfs_cache_pressure       "50"
    w /proc/sys/vm/dirty_expire_centisecs   "100"
    w /proc/sys/vm/dirty_writeback_centisecs "50"
    w /proc/sys/vm/page-cluster             "0"
    w /proc/sys/vm/extra_free_kbytes        "24576"
    local z; for z in /sys/block/zram*/comp_algorithm; do
        [ -f "$z" ] && echo "lz4" > "$z" 2>/dev/null || true; done
}

vm_balanced() {
    w /proc/sys/vm/swappiness               "15"
    w /proc/sys/vm/vfs_cache_pressure       "100"
    w /proc/sys/vm/dirty_expire_centisecs   "3000"
    w /proc/sys/vm/dirty_writeback_centisecs "500"
    w /proc/sys/vm/page-cluster             "0"
    w /proc/sys/vm/extra_free_kbytes        "0"
}

# ═══════════════════════════════════════════════════════════════════════════════
# LMK — nur minfree Node vorhanden (kein adj auf diesem Kernel!)
# ═══════════════════════════════════════════════════════════════════════════════
lmk_gaming() {
    echo "6144,8192,10240,14336,18432,24576" \
        > /sys/module/lowmemorykiller/parameters/minfree 2>/dev/null || true
}

lmk_balanced() {
    echo "4096,5120,6144,7168,8192,9216" \
        > /sys/module/lowmemorykiller/parameters/minfree 2>/dev/null || true
}

# ═══════════════════════════════════════════════════════════════════════════════
# I/O
# ═══════════════════════════════════════════════════════════════════════════════
io_gaming() {
    local q
    for q in /sys/block/*/queue/scheduler; do
        printf '%s' "mq-deadline" > "$q" 2>/dev/null || \
        printf '%s' "deadline"    > "$q" 2>/dev/null || true
    done
    for q in /sys/block/*/queue/add_random; do w "$q" "0"; done
    w /sys/block/mmcblk0/queue/read_ahead_kb "512"
    w /sys/block/mmcblk0/queue/nr_requests   "128"
    w /sys/block/mmcblk0/queue/rq_affinity   "2"
}

io_balanced() {
    local q
    for q in /sys/block/*/queue/scheduler; do
        printf '%s' "cfq" > "$q" 2>/dev/null || \
        printf '%s' "bfq" > "$q" 2>/dev/null || true
    done
    for q in /sys/block/*/queue/add_random; do w "$q" "0"; done
    w /sys/block/mmcblk0/queue/read_ahead_kb "128"
}

# ═══════════════════════════════════════════════════════════════════════════════
# NETWORK
# ═══════════════════════════════════════════════════════════════════════════════
net_gaming() {
    sysctl -w net.ipv4.tcp_congestion_control=bbr      2>/dev/null || true
    sysctl -w net.core.rmem_max=16777216               2>/dev/null || true
    sysctl -w net.core.wmem_max=16777216               2>/dev/null || true
    sysctl -w net.ipv4.tcp_rmem="4096 524288 16777216" 2>/dev/null || true
    sysctl -w net.ipv4.tcp_wmem="4096 524288 16777216" 2>/dev/null || true
    sysctl -w net.core.netdev_max_backlog=20000        2>/dev/null || true
    sysctl -w net.ipv4.tcp_fastopen=3                  2>/dev/null || true
    sysctl -w net.ipv4.tcp_timestamps=1                2>/dev/null || true
    sysctl -w net.ipv4.tcp_sack=1                      2>/dev/null || true
    sysctl -w net.ipv4.tcp_retries2=5                  2>/dev/null || true
    sysctl -w net.ipv4.icmp_ratelimit=0                2>/dev/null || true
    # UDP — CoD Mobile nutzt primär UDP (DTLS)
    # rmem/wmem für UDP vergrößern → weniger Packet-Drops bei Burst
    sysctl -w net.ipv4.udp_rmem_min=32768              2>/dev/null || true
    sysctl -w net.ipv4.udp_wmem_min=32768              2>/dev/null || true
    # Latenz — weniger Nagle-Buffering
    sysctl -w net.ipv4.tcp_low_latency=1               2>/dev/null || true
    sysctl -w net.ipv4.tcp_thin_linear_timeouts=1      2>/dev/null || true
    # ARP Cache — schnellere Auflösung im lokalen Netz (WiFi Router)
    sysctl -w net.ipv4.neigh.default.gc_stale_time=60  2>/dev/null || true
    sysctl -w net.ipv4.neigh.wlan0.gc_stale_time=60    2>/dev/null || true
    # Netfilter conntrack — CoD öffnet viele kurzlebige UDP-Connections
    sysctl -w net.netfilter.nf_conntrack_udp_timeout=30         2>/dev/null || true
    sysctl -w net.netfilter.nf_conntrack_udp_timeout_stream=120 2>/dev/null || true

    # rmnet qdisc — htb→pfifo_fast für niedrigere Latenz auf mobilem Netz
    # htb (Hierarchical Token Bucket) ist für Shaping, nicht für Gaming
    # pfifo_fast: kein Shaping-Overhead, direkter FIFO mit 3 Prioritäts-Bändern
    local iface
    for iface in rmnet_data0 rmnet_data1 rmnet_data2 rmnet_data3 \
                 rmnet_data4 rmnet_data5 rmnet_ipa0; do
        ip link show "$iface" 2>/dev/null | grep -q "UP" || continue
        tc qdisc replace dev "$iface" root pfifo_fast 2>/dev/null || true
        dbg "qdisc: $iface → pfifo_fast"
    done

    # DNS — net.dns1/2 leer auf diesem Gerät (verifiziert)
    # Setze DNS direkt über ndc für das aktive Netz (netId=102 für rmnet_data3)
    # 1.1.1.1 = Cloudflare (latenzarm), 8.8.8.8 = Google Fallback
    local net_id
    net_id=$(dumpsys connectivity 2>/dev/null | grep "Active default" | grep -oE '[0-9]+' | head -1)
    if [ -n "$net_id" ]; then
        ndc resolver setnetdns "$net_id" "" 1.1.1.1 8.8.8.8 2>/dev/null || true
        dbg "DNS: netId=$net_id → 1.1.1.1 / 8.8.8.8"
    fi
    # Fallback via setprop
    setprop net.dns1 "1.1.1.1" 2>/dev/null || true
    setprop net.dns2 "8.8.8.8" 2>/dev/null || true
}

net_restore() {
    sysctl -w net.core.netdev_max_backlog=1000         2>/dev/null || true
    sysctl -w net.ipv4.tcp_retries2=15                 2>/dev/null || true
    sysctl -w net.ipv4.icmp_ratelimit=1000             2>/dev/null || true
    # qdisc auf htb zurücksetzen (Android default)
    local iface
    for iface in rmnet_data0 rmnet_data1 rmnet_data2 rmnet_data3 rmnet_ipa0; do
        ip link show "$iface" 2>/dev/null | grep -q "UP" || continue
        tc qdisc del dev "$iface" root 2>/dev/null || true
    done
    setprop net.dns1 "" 2>/dev/null || true
    setprop net.dns2 "" 2>/dev/null || true
}

# ═══════════════════════════════════════════════════════════════════════════════
# BLUETOOTH
# ═══════════════════════════════════════════════════════════════════════════════
bt_gaming() {
    local irq_dir irq_name
    for irq_dir in /proc/irq/*/; do
        [ -f "${irq_dir}actions" ] || continue
        irq_name=$(cat "${irq_dir}actions" 2>/dev/null)
        echo "$irq_name" | grep -qiE "qca|wcnss|bt|hci|cnss" || continue
        printf '%s' "02" > "${irq_dir}smp_affinity" 2>/dev/null || true
    done
    if hciconfig hci0 2>/dev/null | grep -q "UP"; then
        hciconfig hci0 sniffsubrating 0 2>/dev/null || true
        for bt_dev in /sys/class/bluetooth/hci0/; do
            [ -d "$bt_dev" ] || continue
            echo "on" > "${bt_dev}device/power/control"              2>/dev/null || true
            echo "0"  > "${bt_dev}device/power/autosuspend_delay_ms" 2>/dev/null || true
        done
    fi
}

bt_restore() {
    local irq_dir irq_name
    for irq_dir in /proc/irq/*/; do
        [ -f "${irq_dir}actions" ] || continue
        irq_name=$(cat "${irq_dir}actions" 2>/dev/null)
        echo "$irq_name" | grep -qiE "qca|wcnss|bt|hci|cnss" || continue
        printf '%s' "ff" > "${irq_dir}smp_affinity" 2>/dev/null || true
    done
    for bt_dev in /sys/class/bluetooth/hci0/; do
        [ -d "$bt_dev" ] || continue
        echo "auto" > "${bt_dev}device/power/control" 2>/dev/null || true
    done
}

# ═══════════════════════════════════════════════════════════════════════════════
# BATTERY SPOOF
# ═══════════════════════════════════════════════════════════════════════════════
spoof_battery() {
    [ "$CFG_SPOOF_EN" = "1" ] || return 0
    local c raw
    c=$CFG_SPOOF_T; c=${c:-1}
    raw=$(( c * 10 ))
    [ "$raw" -gt 600 ] && { log "Battery spoof ABORTED: ${c}°C > max 60°C"; return 1; }
    for node in /sys/class/power_supply/battery/temp \
                /sys/class/power_supply/bms/temp; do
        [ -f "$node" ] && printf '%s\n' "$raw" > "$node" 2>/dev/null
    done
    cmd thermalservice override-status 0 2>/dev/null || true
    log "Battery spoof: ${c}°C (raw ${raw})"
}

restore_battery_spoof() {
    # Echten BMS-Wert zurückschreiben — nicht nur thermalservice reset
    # /sys/class/power_supply/battery/temp bleibt sonst dauerhaft auf Spoof-Wert
    local real_temp
    real_temp=$(cat /sys/class/power_supply/bms/temp 2>/dev/null || echo "")
    if [ -n "$real_temp" ] && [ "$real_temp" -gt 0 ] 2>/dev/null; then
        echo "$real_temp" > /sys/class/power_supply/battery/temp 2>/dev/null || true
        log "Battery spoof restored: BMS temp=${real_temp} → battery/temp"
    fi
    cmd thermalservice reset 2>/dev/null || true
}

# ═══════════════════════════════════════════════════════════════════════════════
# GPU DRIVER APK
# ═══════════════════════════════════════════════════════════════════════════════
GPU_DRIVER_PKG="com.qualcomm.qti.gpudrivers.sm7150.api30"
apply_gpu_driver() {
    local installed
    installed=$(pm list packages 2>/dev/null | grep -c "^package:${GPU_DRIVER_PKG}$")
    if [ "${installed:-0}" -gt 0 ]; then
        resetprop ro.gfx.driver.1 "$GPU_DRIVER_PKG" 2>/dev/null || true
        log "GPU Driver APK → ro.gfx.driver.1 gesetzt"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# THREAD PINNING
# ═══════════════════════════════════════════════════════════════════════════════
CODM_PKG="com.activision.callofduty.shooter"

tune_codm() {
    [ "$CFG_THREAD_PIN" = "0" ] && return 0
    local main_pid
    if [ -n "$_CODM_PID_CACHE" ] && [ -d "/proc/$_CODM_PID_CACHE" ]; then
        main_pid="$_CODM_PID_CACHE"
    else
        main_pid=$(pidof "$CODM_PKG" 2>/dev/null | awk '{print $1}')
        if [ -z "$main_pid" ]; then
            main_pid=$(cat /sys/fs/cgroup/top-app/cgroup.procs 2>/dev/null | while read -r p; do
                [ -f "/proc/$p/cmdline" ] || continue
                cmd=$(tr -d '\0' < "/proc/$p/cmdline" 2>/dev/null)
                echo "$cmd" | grep -q "^${CODM_PKG}" && echo "$p" && break
            done)
        fi
        _CODM_PID_CACHE="$main_pid"
    fi
    [ -z "$main_pid" ] && return 0
    local tid thread_name
    for tid in /proc/"$main_pid"/task/*/; do
        tid="${tid%/}"; tid="${tid##*/}"
        [ -f "/proc/$main_pid/task/$tid/comm" ] || continue
        thread_name=$(cat "/proc/$main_pid/task/$tid/comm" 2>/dev/null)
        case "$thread_name" in
            *RenderThread*|*UnityMain*|*GLThread*)
                taskset -p 0xc0 "$tid" >/dev/null 2>&1
                dbg "Pinned $thread_name → Gold (0xc0)" ;;
            *Worker*Thread*|*JobWorker*|*UnityGfx*)
                taskset -p 0x3f "$tid" >/dev/null 2>&1
                dbg "Worker $thread_name → Silver (0x3f)" ;;
            *AudioMixer*|*AudioTrack*)
                taskset -p 0x3f "$tid" >/dev/null 2>&1
                dbg "Audio $thread_name → Silver (0x3f)" ;;
        esac
    done
    local af_pid
    af_pid=$(pidof audioserver 2>/dev/null | awk '{print $1}')
    [ -n "$af_pid" ] && taskset -p 0x3f "$af_pid" >/dev/null 2>&1
}

# ═══════════════════════════════════════════════════════════════════════════════
# THERMAL PREDICTION
# ═══════════════════════════════════════════════════════════════════════════════
THERMAL_PREDICT_TEMP=75
THERMAL_PREDICT_RATE=3
GOLD_MAX_NORMAL="2304000"
GOLD_MAX_CAP="1939200"   # nächstes echtes OPP unter 2304000 (verifiziert)

thermal_predict_check() {
    [ "$STATE" = "GAMING" ] || return 0
    [ "$CFG_THERM_PRED" = "0" ] && return 0
    local curr_temp rate
    curr_temp=$(thermal_cpu_temp)
    if [ "$PREV_TEMP" = "-1" ]; then PREV_TEMP=$curr_temp; return 0; fi
    rate=$(( curr_temp - PREV_TEMP ))
    PREV_TEMP=$curr_temp
    dbg "thermal_predict: ${curr_temp}°C rate=${rate}/tick capped=${THERMAL_CAPPED}"
    if [ "$THERMAL_CAPPED" = "0" ] \
       && [ "$curr_temp" -ge "$THERMAL_PREDICT_TEMP" ] \
       && [ "$rate" -ge "$THERMAL_PREDICT_RATE" ]; then
        w "$P6/scaling_max_freq" "$GOLD_MAX_CAP"
        THERMAL_CAPPED=1
        log "THERMAL_PREDICT: ${curr_temp}°C +${rate}/tick → Gold cap ${GOLD_MAX_CAP}Hz"
    elif [ "$THERMAL_CAPPED" = "1" ] && [ "$curr_temp" -lt "$THERMAL_PREDICT_TEMP" ]; then
        w "$P6/scaling_max_freq" "$GOLD_MAX_NORMAL"
        THERMAL_CAPPED=0
        log "THERMAL_PREDICT aufgehoben: ${curr_temp}°C"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# STATE TRANSITIONS
# ═══════════════════════════════════════════════════════════════════════════════

enter_balanced() {
    log "→ BALANCED"
    # Silver min=576000 (niedrigstes echtes OPP, 300000 existiert nicht!)
    # Gold   min=652800 (niedrigstes echtes OPP)
    cpu_set "schedutil" "576000" "1804800" "652800" "2304000"
    gpu_balanced
    io_balanced
    sched_balanced
    vm_balanced
    lmk_balanced
    net_restore
    bt_restore
    thermal_full_restore
    restore_battery_spoof
    resetprop persist.vendor.battery.bypass_temp_thresh "41" 2>/dev/null || true
    setprop debug.sf.disable_backpressure   "0" 2>/dev/null || true
    setprop debug.sf.enable_gl_backpressure "1" 2>/dev/null || true
    setprop debug.sf.latch_unsignaled       "0" 2>/dev/null || true
    setprop persist.sys.game_mode           "0" 2>/dev/null || true
    setprop persist.vendor.qti.games.gt.fps "0" 2>/dev/null || true
    w /sys/class/power_supply/battery/system_temp_level "0"
    start logd 2>/dev/null || true
    unfreeze_all
    THERMAL_CAPPED=0
    printf '%s' "balanced" > "$PROFILE"
    STATE="BALANCED"
    log "BALANCED: Silver 576-1804MHz | Gold 652-2304MHz | GPU 267-800MHz (governor free)"
}

enter_gaming() {
    log "→ GAMING"
    if [ "$CFG_THERMAL" = "1" ]; then
        thermal_full_disable
        sleep 0.5
    else
        thermal_full_restore
    fi
    # Silver min=1248000 (flüssige Basis für CoD)
    # Gold   min=1843200 (nächstes echtes OPP, 1785600 existiert nicht!)
    cpu_set "schedutil" "1248000" "1804800" "1843200" "2304000"
    gpu_gaming
    io_gaming
    sched_gaming
    vm_gaming
    lmk_gaming
    net_gaming
    bt_gaming
    spoof_battery
    resetprop persist.vendor.battery.bypass_temp_thresh "35" 2>/dev/null || true
    setprop dalvik.vm.heaptargetutilization 0.75  2>/dev/null || true
    setprop dalvik.vm.heapmaxfree           8m    2>/dev/null || true
    setprop debug.sf.disable_backpressure   "1"   2>/dev/null || true
    setprop debug.sf.enable_gl_backpressure "0"   2>/dev/null || true
    setprop debug.sf.set_idle_timer_ms      "0"   2>/dev/null || true
    setprop debug.sf.latch_unsignaled       "1"   2>/dev/null || true
    setprop persist.sys.game_mode           "1"   2>/dev/null || true
    setprop persist.sys.vulkan.perf_mode    "1"   2>/dev/null || true
    setprop persist.vendor.qti.games.gt.fps "120" 2>/dev/null || true
    cmd game set --downscale 1.0 "$CODM_PKG"      2>/dev/null || true
    w /sys/class/power_supply/battery/system_temp_level "0"
    tune_codm
    THERMAL_CAPPED=0
    printf '%s' "gaming" > "$PROFILE"
    STATE="GAMING"
    log "GAMING: Silver 1248-1804MHz | Gold 1843-2304MHz | GPU 650-800MHz | thermal=$CFG_THERMAL"
}

enter_battery() {
    log "→ BATTERY"
    cpu_set "powersave" "576000" "1324800" "652800" "1555200"
    gpu_battery
    io_balanced
    sched_balanced
    vm_balanced
    w /proc/sys/vm/swappiness          "60"
    w /proc/sys/vm/vfs_cache_pressure  "200"
    thermal_full_restore
    restore_battery_spoof
    resetprop persist.vendor.battery.bypass_temp_thresh "41" 2>/dev/null || true
    setprop debug.sf.disable_backpressure "0" 2>/dev/null || true
    setprop persist.sys.game_mode         "0" 2>/dev/null || true
    start logd 2>/dev/null || true
    unfreeze_all
    THERMAL_CAPPED=0
    printf '%s' "battery" > "$PROFILE"
    STATE="BATTERY"
    log "BATTERY: Silver 576-1324MHz | Gold 652-1555MHz | GPU 267-355MHz (powersave)"
}

enter_competitive() {
    log "→ COMPETITIVE"
    thermal_full_disable
    # Silver min=1497600 (echtes OPP), max=1804800
    # Gold   min=2169600 (echtes OPP — maximale stabile Basis), max=2304000
    cpu_set "performance" "1497600" "1804800" "2169600" "2304000"
    gpu_competitive
    io_gaming
    sched_gaming
    vm_gaming
    lmk_gaming
    net_gaming
    bt_gaming
    spoof_battery
    resetprop persist.vendor.battery.bypass_temp_thresh "30" 2>/dev/null || true
    setprop debug.sf.disable_backpressure              "1"   2>/dev/null || true
    setprop debug.sf.enable_gl_backpressure            "0"   2>/dev/null || true
    setprop debug.sf.set_idle_timer_ms                 "0"   2>/dev/null || true
    setprop debug.sf.latch_unsignaled                  "1"   2>/dev/null || true
    setprop persist.sys.game_mode                      "1"   2>/dev/null || true
    setprop persist.sys.vulkan.perf_mode               "1"   2>/dev/null || true
    setprop persist.vendor.qti.games.gt.fps            "120" 2>/dev/null || true
    setprop debug.sf.enable_advanced_sf_phase_offset   "1"   2>/dev/null || true
    setprop debug.sf.high_fps_early_phase_offset_ns    "0"   2>/dev/null || true
    setprop debug.sf.high_fps_early_gl_phase_offset_ns "0"   2>/dev/null || true
    setprop debug.sf.phase_offset_ns                   "0"   2>/dev/null || true
    setprop debug.sf.early_phase_offset_ns             "0"   2>/dev/null || true
    cmd game set --downscale 1.0 "$CODM_PKG"           2>/dev/null || true
    cmd power set-fixed-performance-mode-enabled true  2>/dev/null || true
    w /sys/class/power_supply/battery/system_temp_level "0"
    tune_codm
    THERMAL_CAPPED=0
    printf '%s' "gaming" > "$PROFILE"
    STATE="COMPETITIVE"
    log "COMPETITIVE: Silver 1497-1804MHz | Gold 2169-2304MHz | GPU locked 800MHz | thermal=OFF"
}

enter_thermal_limit() {
    local temp="${1:-82}"
    log "→ THERMAL_LIMIT (${temp}°C)"
    cpu_set "schedutil" "576000" "1248000" "652800" "1555200"
    w $GPU/thermal_pwrlevel "2"           # 565MHz GPU ceiling
    w $GPU/devfreq/max_freq "565000000"
    w $GPU/devfreq/min_freq "267000000"
    sched_balanced
    thermal_full_restore
    PRE_THERMAL_STATE="$STATE"
    printf '%s' "gaming" > "$PROFILE"
    STATE="THERMAL_LIMIT"
    log "THERMAL_LIMIT: cooling from $PRE_THERMAL_STATE, recover <77°C"
}

# ═══════════════════════════════════════════════════════════════════════════════
# APP DETECTION
# ═══════════════════════════════════════════════════════════════════════════════
get_foreground_app() {
    local pid
    pid=$(cat /sys/fs/cgroup/top-app/cgroup.procs 2>/dev/null | head -1)
    [ -z "$pid" ] && pid=$(cat /sys/fs/cgroup/top-app/tasks 2>/dev/null | head -1)
    [ -z "$pid" ] && return
    cat "/proc/${pid}/cmdline" 2>/dev/null | tr -d '\0' | cut -d: -f1
}

is_game_pkg() {
    local pkg="$1" prof
    prof=$(grep "^${pkg}=" "$MODDIR/config/per_app.conf" 2>/dev/null | cut -d= -f2)
    [ "$prof" = "gaming" ]      && return 0
    [ "$prof" = "competitive" ] && return 2
    [ "$prof" = "balanced" ]    && return 1
    [ "$pkg" = "$CODM_PKG" ]    && return 0
    echo "$pkg" | grep -qiE \
        "callofduty|brawlstars|pubgmobile|freefire|mobilelegend|clashof|genshin|honkai|wzm|roblox" \
        && return 0
    return 1
}

is_codm_in_match() {
    local pid
    pid=$(cat /sys/fs/cgroup/top-app/cgroup.procs 2>/dev/null | head -1)
    [ -z "$pid" ] && return 1
    local pkg
    pkg=$(cat "/proc/${pid}/cmdline" 2>/dev/null | tr -d '\0' | cut -d: -f1)
    [ "$pkg" = "$CODM_PKG" ] || return 1
    local threads
    threads=$(grep "^Threads:" "/proc/${pid}/status" 2>/dev/null | awk '{print $2}')
    [ "${threads:-0}" -ge 60 ] && return 0
    return 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# APP FREEZE
# ═══════════════════════════════════════════════════════════════════════════════
_signal_pkg() {
    local sig="$1" pkg="$2" pids
    pids=$(pidof "$pkg" 2>/dev/null); [ -z "$pids" ] && return 0
    local p; for p in $pids; do kill -"$sig" "$p" 2>/dev/null || true; done
}

freeze_for() {
    [ "$STATE" = "GAMING" ] && return 0
    local trigger="$1" targets pkg
    targets=$(grep "^${trigger}=" "$FREEZE" 2>/dev/null | cut -d= -f2)
    [ -z "$targets" ] && return 0
    local IFS_OLD="$IFS"; IFS=','
    for pkg in $targets; do
        pkg=$(printf '%s' "$pkg" | tr -d ' ')
        [ -n "$pkg" ] && _signal_pkg SIGSTOP "$pkg" && log "❄ $pkg"
    done
    IFS="$IFS_OLD"
    printf '%s\n' "$targets" > "$MODDIR/config/frozen_${trigger##*.}"
    grep -v "^#" "$FREEZE" 2>/dev/null > "$FREEZE_DUMP" || true
}

unfreeze_for() {
    local trigger="$1" sf="$MODDIR/config/frozen_${trigger##*.}" targets pkg
    [ -f "$sf" ] || return 0
    targets=$(cat "$sf")
    local IFS_OLD="$IFS"; IFS=','
    for pkg in $targets; do
        pkg=$(printf '%s' "$pkg" | tr -d ' ')
        [ -n "$pkg" ] && _signal_pkg SIGCONT "$pkg"
    done
    IFS="$IFS_OLD"
    rm -f "$sf"
}

unfreeze_all() {
    local sf targets pkg
    for sf in "$MODDIR/config/frozen_"*; do
        [ -f "$sf" ] || continue
        targets=$(cat "$sf")
        local IFS_OLD="$IFS"; IFS=','
        for pkg in $targets; do
            pkg=$(printf '%s' "$pkg" | tr -d ' ')
            [ -n "$pkg" ] && _signal_pkg SIGCONT "$pkg"
        done
        IFS="$IFS_OLD"
        rm -f "$sf"
    done
}

# ═══════════════════════════════════════════════════════════════════════════════
# CACHE / RAM
# ═══════════════════════════════════════════════════════════════════════════════
clean_cache() {
    log "Cache: cleaning (async)"
    # Vollständig async — blockiert den 3s-Loop nicht
    # CACHE_LAST wird nach Abschluss vom Background-Job geschrieben
    {
        find /data/data/*/cache /data/data/*/code_cache \
             /data/user_de/*/*/cache /sdcard/Android/data/*/cache \
             -mindepth 1 -delete 2>/dev/null || true
        sync
        date '+%d.%m.%Y %H:%M:%S' > "$CACHE_LAST"
        log "Cache: done"
    } &
}

clean_ram() {
    [ "$STATE" = "GAMING" ] && { log "RAM: skip (gaming)"; return; }
    log "RAM: cleaning"
    am kill-all 2>/dev/null || true
    sync
    w /proc/sys/vm/drop_caches    "3"
    w /proc/sys/vm/compact_memory "1"
    log "RAM: done"
}

# ═══════════════════════════════════════════════════════════════════════════════
# DATA.TXT — atomic write
# ═══════════════════════════════════════════════════════════════════════════════
write_data() {
    local kern android sdk bat_l bat_s bat_t_raw bat_t
    local ut_raw ut_h ut_m manual_p last_clean ping_val
    local cache_kb mem_total mem_avail mem_used mem_mb
    local freeze_line log_line _disp_state

    kern=$(uname -r 2>/dev/null || printf '?')
    android=$(getprop ro.build.version.release 2>/dev/null || printf '?')
    sdk=$(getprop ro.build.version.sdk 2>/dev/null || printf '?')
    bat_l=$(cat /sys/class/power_supply/battery/capacity 2>/dev/null || printf '?')
    bat_s=$(cat /sys/class/power_supply/battery/status   2>/dev/null || printf '?')
    bat_t_raw=$(cat /sys/class/power_supply/battery/temp 2>/dev/null || printf '0')
    bat_t=$(printf '%s' "$bat_t_raw" | awk '{printf "%.1f",$1/10}')
    ut_raw=$(cut -d. -f1 /proc/uptime 2>/dev/null || printf '0')
    ut_h=$(( ut_raw / 3600 )); ut_m=$(( (ut_raw % 3600) / 60 ))
    manual_p=$(cat "$MANUAL_P" 2>/dev/null || printf 'balanced')
    last_clean=$(cat "$CACHE_LAST" 2>/dev/null || printf '')
    ping_val=$(cat "$MODDIR/config/ping.txt" 2>/dev/null || printf '')
    # ping_stale=1 wenn Gaming/Competitive — Ping wird nicht gemessen, Wert ist veraltet
    local ping_stale=0
    { [ "$STATE" = "GAMING" ] || [ "$STATE" = "COMPETITIVE" ]; } && ping_stale=1
    cache_kb=$(cat "$MODDIR/config/cache_kb.tmp" 2>/dev/null || printf '0')
    { du -sk /data/data/*/cache /data/data/*/code_cache \
        /data/user_de/*/*/cache /sdcard/Android/data/*/cache 2>/dev/null \
        | awk '{s+=$1}END{printf "%d",s+0}' > "$MODDIR/config/cache_kb.tmp"; } &
    mem_total=$(grep MemTotal     /proc/meminfo | awk '{print $2}')
    mem_avail=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
    mem_used=$(( (mem_total - mem_avail) / 1024 ))
    mem_mb=$(( mem_total / 1024 ))

    _disp_state="$STATE"
    [ "$_disp_state" = "COMPETITIVE" ]   && _disp_state="gaming"
    [ "$_disp_state" = "THERMAL_LIMIT" ] && _disp_state="gaming"
    _disp_state=$(printf '%s' "$_disp_state" | tr '[:upper:]' '[:lower:]')

    freeze_line=$(grep -v "^#" "$FREEZE" 2>/dev/null | grep "=" | tr '\n' '|')
    log_line=$(tail -30 "$LOG" 2>/dev/null | tr '\n' '\x01')

    {
        printf 'kernel=%s\n'              "$kern"
        printf 'android=Android %s (API %s)\n' "$android" "$sdk"
        printf 'bat=%s%% - %s\n'         "$bat_l" "$bat_s"
        printf 'bat_temp=%s\n'           "$bat_t"
        printf 'uptime=%sh %sm\n'        "$ut_h" "$ut_m"
        printf 'profile=%s\n'            "$_disp_state"
        printf 'manual_profile=%s\n'     "$manual_p"
        printf 'pid=%s\n'                "$$"
        printf 'cache_kb=%s\n'           "$cache_kb"
        printf 'last_clean=%s\n'         "$last_clean"
        printf 'ping=%s\n'               "$ping_val"
        printf 'ping_stale=%s\n'         "$ping_stale"
        printf 'ram_used=%s\n'           "$mem_used"
        printf 'ram_total=%s\n'          "$mem_mb"
        printf 'conf_thermal=%s\n'       "$CFG_THERMAL"
        printf 'conf_auto=%s\n'          "$CFG_AUTO"
        printf 'conf_spoof_enable=%s\n'  "$CFG_SPOOF_EN"
        printf 'conf_spoof_temp=%s\n'    "$CFG_SPOOF_T"
        printf 'conf_thermal_pred=%s\n'  "$CFG_THERM_PRED"
        printf 'conf_thread_pin=%s\n'    "$CFG_THREAD_PIN"
        printf 'conf_boot_delay=%s\n'    "$CFG_BOOT_DELAY"
        printf 'conf_debug=%s\n'         "$DEBUG"
        printf 'freeze=%s\n'             "$freeze_line"
        printf 'log=%s\n'                "$log_line"
    } > "${DATA}.tmp" && mv "${DATA}.tmp" "$DATA"

    grep -v "^#" "$FREEZE" 2>/dev/null > "$FREEZE_DUMP" || true
}

write_ping() {
    local ms
    ms=$(ping -c 1 -W 2 1.1.1.1 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p')
    printf '%s\n' "${ms:-timeout}" > "$MODDIR/config/ping.txt"
}

cfg_mtime() { stat -c '%Y' "$CONFIG" 2>/dev/null || printf '0'; }

# ═══════════════════════════════════════════════════════════════════════════════
# STARTUP
# ═══════════════════════════════════════════════════════════════════════════════
[ -f "$LOCK" ] && kill "$(cat "$LOCK" 2>/dev/null)" 2>/dev/null || true
printf '%d\n' "$$" > "$LOCK"

DEBUG=$(cfg debug); [ "$DEBUG" != "1" ] && DEBUG=0

log "k6a-controller v7.28 — SM7150 sweet_k6a | Openela 4.14 | Lunaris 3.8"
log "GPU: 8 pwrlevels 140-800MHz | Silver: 576-1804MHz | Gold: 652-2304MHz"
log "Thermal: zone24=Silver(cpuss-0) zone25=Gold(cpuss-1) [verifiziert, zone7/8=BCL!]"
log "Sched: schedtune+uclamp in /dev/cpuset/ | NO core_ctl | NO cpu_boost | HZ=100"

apply_gpu_driver
_cache_fallback_zone

[ -f "$MANUAL_P" ] || printf 'balanced' > "$MANUAL_P"
LAST_CFG_MTIME=$(cfg_mtime)
PREV_TEMP=$(thermal_cpu_temp)

_cfg_load_cache
write_ping &
enter_balanced
write_data

# ── k6a-daemon ────────────────────────────────────────────────────────────────
DAEMON_BIN="$MODDIR/bin/k6a-daemon"
DAEMON_PID_FILE="$MODDIR/run/daemon.pid"
if [ -x "$DAEMON_BIN" ]; then
    [ -f "$DAEMON_PID_FILE" ] && kill "$(cat "$DAEMON_PID_FILE" 2>/dev/null)" 2>/dev/null || true
    "$DAEMON_BIN" "$MODDIR" > "$MODDIR/config/daemon.log" 2>&1 &
    echo $! > "$DAEMON_PID_FILE"
    log "k6a-daemon gestartet (PID $!)"
else
    log "k6a-daemon nicht gefunden"
fi

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN LOOP — 3s tick (CONFIG_HZ=100, 10ms Kernel-Tick)
# ═══════════════════════════════════════════════════════════════════════════════
while true; do

    # ── Trigger files ─────────────────────────────────────────────────────────
    if [ -f "$CACHE_TRIGGER" ]; then rm -f "$CACHE_TRIGGER"; clean_cache; write_data; fi
    if [ -f "$RAM_TRIGGER" ];   then rm -f "$RAM_TRIGGER";   clean_ram;   write_data; fi

    # ── SIGHUP — Config Hot Reload ────────────────────────────────────────────
    if [ "$RELOAD_FLAG" = "1" ]; then
        RELOAD_FLAG=0
        _cfg_load_cache
        _reload_manual=$(cat "$MANUAL_P" 2>/dev/null || printf 'balanced')
        [ "$_reload_manual" = "competitive" ] && [ "$CFG_THERMAL" != "1" ] && _reload_manual="gaming"
        log "SIGHUP: State=$STATE → manual=$_reload_manual"
        LAST_CFG_MTIME=$(cfg_mtime)
        case "$STATE" in
            THERMAL_LIMIT) enter_thermal_limit "$(thermal_cpu_temp)" ;;
            *) case "$_reload_manual" in
                   gaming)      enter_gaming      ;;
                   competitive) enter_competitive ;;
                   battery)     enter_battery     ;;
                   *)           enter_balanced    ;;
               esac ;;
        esac
        write_data
        continue
    fi

    # ── Config mtime fallback ─────────────────────────────────────────────────
    mtime=$(cfg_mtime)
    if [ "$mtime" != "$LAST_CFG_MTIME" ]; then
        LAST_CFG_MTIME="$mtime"
        sleep 0.3
        LAST_CFG_MTIME=$(cfg_mtime)
        _reload_manual=$(cat "$MANUAL_P" 2>/dev/null || printf 'balanced')
        [ "$_reload_manual" = "competitive" ] && [ "$CFG_THERMAL" != "1" ] && _reload_manual="gaming"
        log "Config mtime → manual=$_reload_manual (State=$STATE)"
        _cfg_load_cache
        case "$STATE" in
            THERMAL_LIMIT) enter_thermal_limit "$(thermal_cpu_temp)" ;;
            *) case "$_reload_manual" in
                   gaming)      enter_gaming      ;;
                   competitive) enter_competitive ;;
                   battery)     enter_battery     ;;
                   *)           enter_balanced    ;;
               esac ;;
        esac
        write_data
    fi

    # ── Target State bestimmen ────────────────────────────────────────────────
    TARGET=""
    _mp_raw=$(cat "$MANUAL_P" 2>/dev/null)
    [ -n "$_mp_raw" ] && MANUAL=$_mp_raw || MANUAL=${MANUAL:-balanced}
    [ "$MANUAL" = "competitive" ] && [ "$CFG_THERMAL" != "1" ] && MANUAL="gaming"

    if [ "$STATE" = "THERMAL_LIMIT" ]; then
        temp=$(thermal_cpu_temp)
        if [ "${temp:-99}" -lt 77 ]; then
            TARGET="${PRE_THERMAL_STATE:-GAMING}"
            log "Thermal recovery → $TARGET (${temp}°C)"
        fi

    elif [ "$CFG_AUTO" = "1" ] && [ $(( TICK % 5 )) -eq 0 ]; then
        APP=$(get_foreground_app)
        if [ -n "$APP" ] && [ "$APP" != "$LAST_APP" ]; then
            LAST_APP="$APP"
            if [ "$STATE" != "GAMING" ]; then
                [ -n "$LAST_FREEZE_TRIGGER" ] && [ "$APP" != "$LAST_FREEZE_TRIGGER" ] && {
                    unfreeze_for "$LAST_FREEZE_TRIGGER"; LAST_FREEZE_TRIGGER=""
                }
                grep -q "^${APP}=" "$FREEZE" 2>/dev/null && {
                    freeze_for "$APP"; LAST_FREEZE_TRIGGER="$APP"
                }
            fi
            is_game_pkg "$APP"; _GRET=$?
            if [ "$_GRET" -eq 2 ]; then
                TARGET="COMPETITIVE"
            elif [ "$_GRET" -eq 0 ]; then
                if [ "$APP" = "$CODM_PKG" ] && [ "$MANUAL" = "competitive" ] \
                   && is_codm_in_match; then
                    TARGET="COMPETITIVE"
                else
                    TARGET="GAMING"
                fi
            else
                case "$MANUAL" in
                    gaming)      TARGET="GAMING"      ;;
                    competitive) TARGET="COMPETITIVE" ;;
                    battery)     TARGET="BATTERY"     ;;
                    *)           TARGET="BALANCED"    ;;
                esac
            fi
        else
            case "$MANUAL" in
                gaming)      TARGET="GAMING"      ;;
                competitive) TARGET="COMPETITIVE" ;;
                battery)     TARGET="BATTERY"     ;;
                *)           TARGET="BALANCED"    ;;
            esac
        fi
    else
        case "$MANUAL" in
            gaming)      TARGET="GAMING"      ;;
            competitive) TARGET="COMPETITIVE" ;;
            battery)     TARGET="BATTERY"     ;;
            *)           TARGET="BALANCED"    ;;
        esac
    fi

    # ── Thermal override + Watchdogs ──────────────────────────────────────────
    if [ "$STATE" = "GAMING" ] || [ "$STATE" = "COMPETITIVE" ]; then
        temp=$(thermal_cpu_temp)
        [ "${temp:-0}" -ge 84 ] && TARGET="THERMAL_LIMIT"
        thermal_predict_check

        [ $(( TICK % 3 )) -eq 0 ] && tune_codm
        [ $(( TICK % 3 )) -eq 0 ] && apply_irq_affinity

        _stl=$(cat /sys/class/power_supply/battery/system_temp_level 2>/dev/null || echo 0)
        [ "${_stl:-0}" -gt "0" ] && {
            w /sys/class/power_supply/battery/system_temp_level "0"
            dbg "system_temp_level ${_stl}→0"
        }

        # GPU Watchdog — alle 2 Ticks
        if [ $(( TICK % 2 )) -eq 0 ]; then
            _gpu_min=$(cat $GPU/devfreq/min_freq  2>/dev/null || echo 0)
            _gpu_clk=$(cat $GPU/force_clk_on      2>/dev/null || echo 1)
            _gpu_tpwrl=$(cat $GPU/thermal_pwrlevel 2>/dev/null || echo 0)
            if [ "$_gpu_min" -lt "640000000" ] || [ "$_gpu_clk" != "1" ] || [ "$_gpu_tpwrl" -gt "0" ]; then
                dbg "GPU correcting: min=${_gpu_min} clk=${_gpu_clk} tpwrl=${_gpu_tpwrl}"
                w $GPU/thermal_pwrlevel  "0"
                w $GPU/devfreq/min_freq  "650000000"
                w $GPU/devfreq/max_freq  "800000000"
                w $GPU/min_pwrlevel      "$GPU_LVL_650"
                w $GPU/max_pwrlevel      "$GPU_LVL_800"
                w $GPU/force_clk_on      "1"
                w $GPU/force_bus_on      "1"
                echo "0" > "$GPU/throttling" 2>/dev/null || true
            fi
        fi

        # CPU-Freeze Watchdog — alle 3 Ticks
        if [ $(( TICK % 3 )) -eq 0 ]; then
            _cur_max=$(cat "$P0/scaling_max_freq" 2>/dev/null || echo 9999999)
            _cur_min=$(cat "$P0/scaling_min_freq" 2>/dev/null || echo 0)
            if [ "$_cur_max" -lt "1700000" ] || [ "$_cur_min" = "$_cur_max" ]; then
                log "CPU FREEZE (Silver max=${_cur_max}) — re-kill thermal + re-apply"
                for _te in $(pgrep -f "thermal-engine\|mi_thermald" 2>/dev/null); do
                    kill -9 "$_te" 2>/dev/null || true
                done
                if [ "$STATE" = "COMPETITIVE" ]; then
                    cpu_set "performance" "1497600" "1804800" "2169600" "2304000"
                else
                    cpu_set "schedutil" "1248000" "1804800" "1843200" "2304000"
                fi
                w $GPU/thermal_pwrlevel  "0"
                w $GPU/devfreq/min_freq  "650000000"
                w $GPU/devfreq/max_freq  "800000000"
                w $GPU/force_clk_on      "1"
                echo "0" > "$GPU/throttling" 2>/dev/null || true
                w /sys/class/power_supply/battery/system_temp_level "0"
                apply_irq_affinity
                log "CPU+GPU+IRQ recovered"
            fi
        fi
    fi

    # ── State transition ──────────────────────────────────────────────────────
    if [ -n "$TARGET" ] && [ "$TARGET" != "$STATE" ]; then
        log "Transition: $STATE → $TARGET"
        case "$TARGET" in
            GAMING)        enter_gaming                      ;;
            COMPETITIVE)   enter_competitive                 ;;
            BATTERY)       enter_battery                     ;;
            THERMAL_LIMIT) enter_thermal_limit "${temp:-82}" ;;
            BALANCED)      enter_balanced                    ;;
        esac
        write_data
    fi

    TICK=$(( TICK + 1 ))
    [ $(( TICK % 3 )) -eq 0 ] && write_data
    [ "$STATE" != "GAMING" ] && [ "$STATE" != "COMPETITIVE" ] && \
        [ $(( TICK % 10 )) -eq 0 ] && write_ping &
    [ $(( TICK % 200 )) -eq 0 ] && log "♥ $STATE tick=$TICK temp=$(thermal_cpu_temp)°C"
    [ $(( TICK % 1000 )) -eq 0 ] && trim_log

    sleep 3
done
